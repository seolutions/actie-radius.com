---
layout: base.njk
title: Fitness
permalink: /category/fitness/
---

<section class="category-hero">
  <div class="container">
    <div class="category-hero-icon">&#x1F4AA;</div>
    <h1 class="page-title">Fitness</h1>
    <p class="page-subtitle">Workouts, training programs, and fitness motivation</p>
  </div>
</section>

<section class="category-posts">
  <div class="container">
    <div class="posts-grid">
      {% for post in collections.cat_fitness %}
      <article class="post-card">
        <div class="post-card-body">
          <div class="post-card-meta">
            <span class="category-label">Fitness</span>
            <time datetime="{{ post.data.date }}">{{ post.data.date | dateShort }}</time>
          </div>
          <h3><a href="{{ post.url }}">{{ post.data.title }}</a></h3>
          <p class="post-card-excerpt">{{ post.content | excerpt }}</p>
        </div>
        <div class="post-card-footer">
          <a href="{{ post.url }}" class="read-more">Read More &rarr;</a>
        </div>
      </article>
      {% endfor %}
    </div>
  </div>
</section>
